# -------------------------------------------------------
# Weather API — Environment Configuration
# Copy this file to .env and fill in the values.
# .env is gitignored and should never be committed.
# -------------------------------------------------------

# Absolute path to the DAYMET weather parquet file on yourr server
WEATHER_PARQUET_PATH="changeme"

# API key that clients must supply in the X-API-Key header
WEATHER_API_KEY="changeme"

# Uvicorn host/port (please override accordingly)
HOST=0.0.0.0
PORT=8001
